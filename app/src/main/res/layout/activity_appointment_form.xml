<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f3f4f6"
    tools:context=".Activity.AppointmentFormActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:elevation="4dp"
            android:padding="24dp">

            <!-- Header Icon -->
            <ImageView
                android:id="@+id/iv_medical_icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_medical_square"
                android:contentDescription="@string/medical_icon"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Main Title -->
            <TextView
                android:id="@+id/tv_main_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/medical_appointment"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1f2937"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/iv_medical_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Doctor Name -->
            <TextView
                android:id="@+id/tv_doctor_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dr_john_doe"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2563eb"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tv_main_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Section Title -->
            <TextView
                android:id="@+id/tv_section_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/patient_s_details"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/tv_doctor_name"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- First Name -->
            <TextView
                android:id="@+id/tv_first_name_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/first_name"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_section_title" />

            <EditText
                android:id="@+id/et_first_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:autofillHints=""
                android:background="@drawable/rounded_edittext_background"
                android:drawableStart="@drawable/ic_person_outline"
                android:drawablePadding="12dp"
                android:hint="@string/patients_first_name"
                android:inputType="textPersonName|textCapWords"
                android:minHeight="48dp"
                android:padding="14dp"
                android:textColor="#1f2937"
                android:textColorHint="#9ca3af"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_first_name_label" />

            <!-- Last Name -->
            <TextView
                android:id="@+id/tv_last_name_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/patients_last_name"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_first_name" />

            <EditText
                android:id="@+id/et_last_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:autofillHints=""
                android:background="@drawable/rounded_edittext_background"
                android:drawableStart="@drawable/ic_person_outline"
                android:drawablePadding="12dp"
                android:hint="@string/last_name"
                android:inputType="textPersonName|textCapWords"
                android:minHeight="48dp"
                android:padding="14dp"
                android:textColor="#1f2937"
                android:textColorHint="#9ca3af"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_last_name_label" />

            <!-- Date of Birth -->
            <TextView
                android:id="@+id/tv_dob_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/date_of_birth"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_last_name" />

            <EditText
                android:id="@+id/et_date_of_birth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:autofillHints="birthDate"
                android:background="@drawable/rounded_edittext_background"
                android:drawableStart="@drawable/ic_calendar_outline"
                android:drawablePadding="12dp"
                android:hint="@string/select_date_of_birth"
                android:inputType="none"
                android:focusable="true"
                android:clickable="true"
                android:minHeight="48dp"
                android:padding="14dp"
                android:textColor="#1f2937"
                android:textColorHint="#9ca3af"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_dob_label"
                tools:ignore="TextFields" />

            <!-- Gender -->
            <TextView
                android:id="@+id/tv_gender_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gender"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_date_of_birth" />

            <Spinner
                android:id="@+id/spinner_gender"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_edittext_background"
                android:minHeight="48dp"
                android:padding="14dp"
                android:popupBackground="#ffffff"
                android:dropDownVerticalOffset="4dp"
                android:dropDownHeight="160dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_gender_label" />

            <!-- Contact Number -->
            <TextView
                android:id="@+id/tv_contact_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/contact_number"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/spinner_gender" />

            <EditText
                android:id="@+id/et_contact_number"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:autofillHints="phone"
                android:background="@drawable/rounded_edittext_background"
                android:drawableStart="@drawable/ic_phone_outline"
                android:drawablePadding="12dp"
                android:hint="@string/_880_123_456_789"
                android:inputType="phone"
                android:minHeight="48dp"
                android:padding="14dp"
                android:textColor="#1f2937"
                android:textColorHint="#9ca3af"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_contact_label" />

            <!-- Email ID -->
            <TextView
                android:id="@+id/tv_email_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/email_id"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_contact_number" />

            <EditText
                android:id="@+id/et_email"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:autofillHints="email"
                android:background="@drawable/rounded_edittext_background"
                android:drawableStart="@drawable/ic_email_outline"
                android:drawablePadding="12dp"
                android:hint="@string/enter_patient_s_email_id"
                android:inputType="textEmailAddress"
                android:minHeight="48dp"
                android:padding="14dp"
                android:textColor="#1f2937"
                android:textColorHint="#9ca3af"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_email_label" />

            <!-- Available Dates -->
            <TextView
                android:id="@+id/tv_available_dates_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/available_dates"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_email" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/availableDatesRecyclerView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_available_dates_label" />

            <!-- Available Times -->
            <TextView
                android:id="@+id/tv_available_times_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/available_times"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/availableDatesRecyclerView" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/availableTimesRecyclerView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_available_times_label" />

            <!-- Message -->
            <TextView
                android:id="@+id/tv_message_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/message_optional"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/availableTimesRecyclerView" />

            <EditText
                android:id="@+id/et_message"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:autofillHints="message"
                android:background="@drawable/rounded_edittext_background"
                android:gravity="top|start"
                android:hint="@string/enter_any_additional_message_or_special_requirements"
                android:inputType="textMultiLine|textCapSentences"
                android:lines="5"
                android:maxLines="5"
                android:minHeight="120dp"
                android:padding="14dp"
                android:scrollbars="vertical"
                android:textColor="#1f2937"
                android:textColorHint="#9ca3af"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_message_label" />

            <!-- Submit Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_submit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/submit_button_background"
                android:minHeight="48dp"
                android:text="@string/confirm_appointment"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_message" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>