<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f3f4f6"
    tools:context=".Activity.AppointmentFormActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:elevation="4dp"
            android:padding="24dp">

            <!-- Header Icon -->
            <ImageView
                android:id="@+id/iv_medical_icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_medical_square"
                android:contentDescription="Medical Icon"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Main Title -->
            <TextView
                android:id="@+id/tv_main_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medical Appointment"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1f2937"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/iv_medical_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Doctor Name -->
            <TextView
                android:id="@+id/tv_doctor_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dr. John Doe"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2563eb"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tv_main_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Section Title -->
            <TextView
                android:id="@+id/tv_section_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Patient's Details"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/tv_doctor_name"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- First Name -->
            <TextView
                android:id="@+id/tv_first_name_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="First Name *"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_section_title" />

            <EditText
                android:id="@+id/et_first_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_edittext_background"
                android:drawableStart="@drawable/ic_person_outline"
                android:drawablePadding="12dp"
                android:hint="First Name"
                android:inputType="textPersonName|textCapWords"
                android:minHeight="48dp"
                android:padding="14dp"
                android:textColor="#1f2937"
                android:textColorHint="#9ca3af"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_first_name_label" />

            <!-- Last Name -->
            <TextView
                android:id="@+id/tv_last_name_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last Name *"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_first_name" />

            <EditText
                android:id="@+id/et_last_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_edittext_background"
                android:drawableStart="@drawable/ic_person_outline"
                android:drawablePadding="12dp"
                android:hint="Last Name"
                android:inputType="textPersonName|textCapWords"
                android:minHeight="48dp"
                android:padding="14dp"
                android:textColor="#1f2937"
                android:textColorHint="#9ca3af"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_last_name_label" />

            <!-- Date of Birth -->
            <TextView
                android:id="@+id/tv_dob_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date of Birth *"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_last_name" />

            <EditText
                android:id="@+id/et_date_of_birth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_edittext_background"
                android:drawableStart="@drawable/ic_calendar_outline"
                android:drawablePadding="12dp"
                android:hint="Select Date of Birth"
                android:inputType="none"
                android:focusable="false"
                android:clickable="true"
                android:minHeight="48dp"
                android:padding="14dp"
                android:textColor="#1f2937"
                android:textColorHint="#9ca3af"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_dob_label" />

            <!-- Gender -->
            <TextView
                android:id="@+id/tv_gender_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gender *"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_date_of_birth" />

            <Spinner
                android:id="@+id/spinner_gender"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_edittext_background"
                android:minHeight="48dp"
                android:padding="14dp"
                android:popupBackground="#ffffff"
                android:dropDownVerticalOffset="4dp"
                android:dropDownHeight="160dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_gender_label" />

            <!-- Contact Number -->
            <TextView
                android:id="@+id/tv_contact_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact Number *"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/spinner_gender" />

            <EditText
                android:id="@+id/et_contact_number"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_edittext_background"
                android:drawableStart="@drawable/ic_phone_outline"
                android:drawablePadding="12dp"
                android:hint="+1 201-555-0123"
                android:inputType="phone"
                android:minHeight="48dp"
                android:padding="14dp"
                android:textColor="#1f2937"
                android:textColorHint="#9ca3af"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_contact_label" />

            <!-- Email ID -->
            <TextView
                android:id="@+id/tv_email_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email id"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_contact_number" />

            <EditText
                android:id="@+id/et_email"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_edittext_background"
                android:drawableStart="@drawable/ic_email_outline"
                android:drawablePadding="12dp"
                android:hint="Enter patient's email id"
                android:inputType="textEmailAddress"
                android:minHeight="48dp"
                android:padding="14dp"
                android:textColor="#1f2937"
                android:textColorHint="#9ca3af"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_email_label" />

            <!-- Message -->
            <TextView
                android:id="@+id/tv_message_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Message (Optional)"
                android:textColor="#1f2937"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_email" />

            <EditText
                android:id="@+id/et_message"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_edittext_background"
                android:gravity="top|start"
                android:hint="Enter any additional message or special requirements..."
                android:inputType="textMultiLine|textCapSentences"
                android:lines="5"
                android:maxLines="5"
                android:minHeight="120dp"
                android:padding="14dp"
                android:scrollbars="vertical"
                android:textColor="#1f2937"
                android:textColorHint="#9ca3af"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_message_label" />

            <!-- Submit Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_submit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/submit_button_background"
                android:minHeight="48dp"
                android:text="Confirm Appointment"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_message" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>